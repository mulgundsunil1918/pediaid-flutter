<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy Auto Backup rules (Android 6-11, API 23-30) referenced by
  android:fullBackupContent. From Android 12+ Android uses
  data_extraction_rules.xml instead. With allowBackup="false" this
  file's behaviour is moot, but Lint validates its structure against
  the schema.
-->
<full-backup-content>
    <include domain="sharedpref" path="." />
    <exclude domain="sharedpref" path="." />
    <include domain="file" path="." />
    <exclude domain="file" path="." />
    <include domain="database" path="." />
    <exclude domain="database" path="." />
    <include domain="external" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
